# Copia este archivo a .env y rellena los valores.

# PostgreSQL (BD analítica alimentada por el ETL del ERP)
PG_HOST=10.0.0.12
PG_DB=gyc_analytics
PG_USER=gyc_etl
PG_PASS=
PG_PORT=5434

# Refresco bajo demanda del ETL (Prefect self-hosted) — opcional
PREFECT_API_URL=http://10.0.0.12:4200/api
PREFECT_DEPLOYMENT_ID=
PREFECT_API_KEY=

# ERP origen (SQL Server GOMEZYCRESPO) — solo lo usa el Consultor de Bonos,
# que necesita estado en vivo y no puede esperar al refresco del ETL.
SQLSERVER_HOST=10.0.0.6
SQLSERVER_DB=GOMEZYCRESPO
SQLSERVER_USER=
SQLSERVER_PASS=
